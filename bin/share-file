#!/usr/bin/env bash
# share-file: publish a file as a GitHub gist, return a rendered viewer URL
set -euo pipefail

# Resolve viewer URL: env var > local config > public default.
# Self-hosters: `bin/setup` writes ~/.config/share-file/viewer.
VIEWER_BASE="${SHARE_FILE_VIEWER:-}"
if [[ -z "$VIEWER_BASE" ]] && [[ -f "$HOME/.config/share-file/viewer" ]]; then
  VIEWER_BASE=$(cat "$HOME/.config/share-file/viewer")
fi
VIEWER_BASE="${VIEWER_BASE:-https://alecgard.github.io/share-file/}"
SIZE_LIMIT=900000  # ~900KB; gist API gets unreliable above 1MB
KEY_CACHE_DIR="$HOME/.config/share-file/keys"

# Stash an encrypted share's key locally so `share-file --created` can rebuild the URL.
# Cached on every encrypted create/update/view/read.
cache_key() {
  local gist_id="$1" key="$2"
  [[ -n "$gist_id" && -n "$key" ]] || return 0
  mkdir -p "$KEY_CACHE_DIR"
  chmod 700 "$KEY_CACHE_DIR" 2>/dev/null || true
  printf '%s' "$key" > "$KEY_CACHE_DIR/$gist_id"
  chmod 600 "$KEY_CACHE_DIR/$gist_id"
}

usage() {
  cat <<EOF >&2
share-file: publish a file to a shareable URL via GitHub gist

Usage:
  share-file [flags] <file>
  share-file [flags] --stdin --filename <name>
  share-file [flags] --update <id>[#k=<key>] <file>
  share-file --view <id>[#k=<key>]
  share-file --read <id>[#k=<key>]
  share-file --created [--json]
  share-file --upgrade

Shares are encrypted by default: content is AES-128-CBC encrypted client-side
(HMAC-SHA256 authenticated) and the decryption key is appended to the rendered
URL as a fragment (#k=...), so GitHub stores only ciphertext. Lose the URL =
lose the content; there is no recovery.

A share is identified by its gist ID. Encrypted shares also need a key,
appended as "<id>#k=<key>". A full rendered URL is accepted anywhere an
ID is, as a convenience for paste-from-clipboard.

Flags:
  --no-encrypt        Skip encryption (plaintext content in the gist). The
                      gist ID is unguessable for secret gists but anyone with
                      the link reads the content directly.
  --public            Create a public (listed) gist that shows up on your
                      GitHub gist profile (default: secret/unlisted).
                      Independent of --no-encrypt; encrypted public gists are
                      allowed but unusual.
  --desc <text>       Gist description shown on GitHub. Server-visible
                      regardless of encryption — only the file content is
                      encrypted, not the description.
  --update <id>[#k=<key>]
                      Update an existing gist. Encrypted shares need the key
                      so the same one is reused and the URL stays stable.
                      Mode switches (plain<->encrypted) are supported and
                      warn that the rendered URL changes.
  --view <id>[#k=<key>]
                      Fetch, decrypt locally, and open in the default browser
                      via a temporary local HTML wrapper (no third-party
                      viewer involved). The wrapper is left in \$TMPDIR for
                      the OS to clean up so browser refresh keeps working.
  --read <id>[#k=<key>]
                      Like --view but emit the decoded content as JSON to
                      stdout instead of opening a browser. Useful for agents
                      and scripts that need the content rather than a preview.
  --created           List every share-file gist on your account, one per line:
                      timestamp, type (plain/encrypted), and rendered URL with
                      decryption key when known. --created --json for JSON.
  --upgrade           Re-download the latest share-file script (and the agent
                      skill, if installed) from the upstream repo, overwriting
                      the current install in place. Refuses to run if the
                      script lives inside a git clone — use 'git pull' there.
  --stdin             Read content from stdin (requires --filename)
  --filename <name>   Filename to use (overrides basename / required with --stdin)
  --mime <type>       Override MIME type detection
  --json              Output JSON (for agents and scripts)
  -h, --help          Show this help

Renderable in the viewer: HTML, images (PNG/JPG/GIF/SVG/WebP), PDF,
plain text / source / JSON / XML / Markdown, audio, video. Other types
produce a download link. Binary files are base64-encoded into the gist.

Requires: gh (https://cli.github.com), jq, file, openssl, xxd. Authenticated via 'gh auth login'.
EOF
  exit "${1:-2}"
}

# Track temp files/dirs for cleanup on exit.
TMP_PATHS=()
cleanup_tmp() {
  (( ${#TMP_PATHS[@]} == 0 )) && return
  rm -rf "${TMP_PATHS[@]}"
}
trap cleanup_tmp EXIT

reg_tmp() {
  TMP_PATHS+=("$1")
  printf '%s' "$1"
}

# Decode unpadded base64url ($1) to binary file ($2).
b64url_decode_to() {
  local s="$1" out="$2" pad
  pad=$(( (4 - ${#s} % 4) % 4 ))
  while (( pad-- > 0 )); do s="${s}="; done
  printf '%s' "$s" | tr '_-' '/+' | openssl base64 -d -A > "$out"
}

# Encrypt stdin with AES-128-CBC + HMAC-SHA256.
# $1 (optional): existing base64url master key (for re-encrypting on update).
# Outputs to stdout: <master_key_b64url><newline><payload_b64>
# Payload format: base64( IV(16) || ciphertext || HMAC-SHA256(32) ).
# Keys derived from master: enc = first16(SHA256(0x01||M)), mac = SHA256(0x02||M).
encrypt_payload() {
  local existing_key="${1:-}"
  local d
  d=$(reg_tmp "$(mktemp -d)")
  cat > "$d/plain.bin"
  if [[ -n "$existing_key" ]]; then
    b64url_decode_to "$existing_key" "$d/master.bin"
    [[ $(wc -c < "$d/master.bin") -eq 16 ]] || {
      echo "error: cached key for this gist is malformed (expected 16 bytes)" >&2
      return 1
    }
  else
    openssl rand 16 > "$d/master.bin"
  fi
  openssl rand 16 > "$d/iv.bin"
  local enc_key_hex mac_key_hex iv_hex
  enc_key_hex=$( { printf '\x01'; cat "$d/master.bin"; } | \
    openssl dgst -sha256 -binary | head -c 16 | xxd -p -c 256)
  mac_key_hex=$( { printf '\x02'; cat "$d/master.bin"; } | \
    openssl dgst -sha256 -binary | xxd -p -c 256)
  iv_hex=$(xxd -p -c 256 < "$d/iv.bin")
  openssl enc -aes-128-cbc -K "$enc_key_hex" -iv "$iv_hex" \
    -in "$d/plain.bin" -out "$d/ct.bin"
  cat "$d/iv.bin" "$d/ct.bin" | \
    openssl dgst -sha256 -mac HMAC -macopt "hexkey:$mac_key_hex" -binary > "$d/mac.bin"
  local payload_b64 master_b64url
  payload_b64=$(cat "$d/iv.bin" "$d/ct.bin" "$d/mac.bin" | openssl base64 -A)
  master_b64url=$(openssl base64 -A < "$d/master.bin" | tr -d '=' | tr '+/' '-_')
  printf '%s\n%s' "$master_b64url" "$payload_b64"
}

# Decrypt base64-encoded payload from stdin using master key $1 (base64url).
# Outputs plaintext to stdout. Verifies HMAC before decrypting.
decrypt_payload() {
  local key_b64url="$1"
  local d
  d=$(reg_tmp "$(mktemp -d)")
  openssl base64 -d -A > "$d/payload.bin"
  b64url_decode_to "$key_b64url" "$d/master.bin"
  [[ $(wc -c < "$d/master.bin") -eq 16 ]] || {
    echo "error: invalid key length (expected 16 bytes)" >&2; return 1; }
  local size=$(wc -c < "$d/payload.bin") iv_size=16 mac_size=32
  local ct_size=$((size - iv_size - mac_size))
  (( ct_size > 0 )) || { echo "error: encrypted payload too short" >&2; return 1; }
  dd if="$d/payload.bin" of="$d/iv.bin"  bs=1 count=$iv_size                       2>/dev/null
  dd if="$d/payload.bin" of="$d/ct.bin"  bs=1 skip=$iv_size count=$ct_size         2>/dev/null
  dd if="$d/payload.bin" of="$d/mac.bin" bs=1 skip=$((iv_size + ct_size))          2>/dev/null
  local enc_key_hex mac_key_hex iv_hex
  enc_key_hex=$( { printf '\x01'; cat "$d/master.bin"; } | \
    openssl dgst -sha256 -binary | head -c 16 | xxd -p -c 256)
  mac_key_hex=$( { printf '\x02'; cat "$d/master.bin"; } | \
    openssl dgst -sha256 -binary | xxd -p -c 256)
  iv_hex=$(xxd -p -c 256 < "$d/iv.bin")
  local expected actual
  expected=$(cat "$d/iv.bin" "$d/ct.bin" | \
    openssl dgst -sha256 -mac HMAC -macopt "hexkey:$mac_key_hex" -binary | xxd -p -c 256)
  actual=$(xxd -p -c 256 < "$d/mac.bin")
  if [[ "$expected" != "$actual" ]]; then
    echo "error: HMAC verification failed (wrong key or tampered data)" >&2
    return 1
  fi
  openssl enc -d -aes-128-cbc -K "$enc_key_hex" -iv "$iv_hex" -in "$d/ct.bin"
}

# Parse --update/--view target. Canonical form is "<id>" (plain) or
# "<id>#k=<key>" (encrypted); a full rendered URL is also accepted.
# Sets $parsed_id and $parsed_key (key empty if not in fragment).
parse_target() {
  local t="$1"
  parsed_id="$t"
  parsed_key=""
  # Strip URL prefix if present, leaving "id" / "id#k=KEY" / "id&..." behind.
  if [[ "$t" == *"?"* ]]; then
    t="${t#*\?}"
  fi
  if [[ "$t" == *"#"* ]]; then
    parsed_id="${t%%#*}"
    local frag="${t#*#}"
    case "$frag" in
      k=*)  parsed_key="${frag#k=}";   parsed_key="${parsed_key%%&*}" ;;
      *k=*) parsed_key="${frag##*k=}"; parsed_key="${parsed_key%%&*}" ;;
    esac
  else
    parsed_id="$t"
  fi
  parsed_id="${parsed_id%%&*}"
}

# Re-download the latest script (and skill, if installed) from upstream and
# overwrite the current install. Honors $SHARE_FILE_UPSTREAM / $SHARE_FILE_SKILL_DIR
# so self-hosters can upgrade from their fork; defaults match bin/setup.
self_upgrade() {
  command -v curl >/dev/null || { echo "error: curl not installed" >&2; exit 1; }

  local upstream="${SHARE_FILE_UPSTREAM:-alecgard/share-file}"

  # Resolve $0 (which may be a symlink, or a relative path) to a canonical path.
  local script_path="$0"
  while [[ -L "$script_path" ]]; do
    local link
    link=$(readlink "$script_path")
    if [[ "$link" = /* ]]; then
      script_path="$link"
    else
      script_path="$(cd "$(dirname "$script_path")" && pwd)/$link"
    fi
  done
  script_path="$(cd "$(dirname "$script_path")" && pwd)/$(basename "$script_path")"

  # If we're running from a git clone, overwriting the working tree is the
  # wrong thing — point the user at `git pull` instead.
  if command -v git >/dev/null 2>&1 && \
     git -C "$(dirname "$script_path")" rev-parse --show-toplevel >/dev/null 2>&1; then
    echo "error: ${script_path} is inside a git clone — use 'git pull' instead" >&2
    exit 1
  fi

  echo "Upgrading share-file from ${upstream}"
  echo "  Script: ${script_path}"

  local tmp_script
  tmp_script=$(mktemp)
  TMP_PATHS+=("$tmp_script")
  curl -fsSL "https://raw.githubusercontent.com/${upstream}/main/bin/share-file" \
    -o "$tmp_script" || { echo "error: failed to download new script" >&2; exit 1; }
  chmod +x "$tmp_script"
  mv "$tmp_script" "$script_path" || {
    echo "error: failed to write ${script_path}" >&2; exit 1; }

  local skill_file="${SHARE_FILE_SKILL_DIR:-$HOME/.claude/skills/share-file}/SKILL.md"
  if [[ -f "$skill_file" ]]; then
    echo "  Skill:  ${skill_file}"
    local tmp_skill
    tmp_skill=$(mktemp)
    TMP_PATHS+=("$tmp_skill")
    curl -fsSL "https://raw.githubusercontent.com/${upstream}/main/skill/SKILL.md" \
      -o "$tmp_skill" || { echo "error: failed to download skill" >&2; exit 1; }
    mv "$tmp_skill" "$skill_file" || {
      echo "error: failed to write ${skill_file}" >&2; exit 1; }
  fi

  echo "Done."
  exit 0
}

main() {
desc="Shared file"
public=false
no_encrypt=false
update_id=""
view_target=""
read_target=""
list_created=false
use_stdin=false
output_json=false
file=""
filename_override=""
mime_override=""

while [[ $# -gt 0 ]]; do
  case "$1" in
    --desc)       desc="$2"; shift 2 ;;
    --public)     public=true; shift ;;
    --no-encrypt) no_encrypt=true; shift ;;
    --update)     update_id="$2"; shift 2 ;;
    --view)       view_target="$2"; shift 2 ;;
    --read)       read_target="$2"; shift 2 ;;
    --created)    list_created=true; shift ;;
    --stdin)      use_stdin=true; shift ;;
    --filename)   filename_override="$2"; shift 2 ;;
    --mime)       mime_override="$2"; shift 2 ;;
    --json)       output_json=true; shift ;;
    --upgrade)    self_upgrade ;;
    -h|--help)    usage 0 ;;
    -*) echo "unknown flag: $1" >&2; usage ;;
    *)  file="$1"; shift ;;
  esac
done

# --public and --no-encrypt are independent: --public controls listed-vs-secret
# gist visibility, --no-encrypt controls whether the content is encrypted. An
# encrypted public gist is unusual (anyone browsing your profile finds
# ciphertext) but allowed.
encrypt=true
$no_encrypt && encrypt=false

if [[ -n "$view_target" && -n "$read_target" ]]; then
  echo "error: --view and --read are mutually exclusive" >&2
  exit 1
fi
fetch_target="${view_target:-$read_target}"
if [[ -n "$fetch_target" ]]; then
  if $no_encrypt || $public || [[ -n "$update_id" ]] || $use_stdin || \
     [[ -n "$file" ]] || [[ -n "$filename_override" ]] || [[ -n "$mime_override" ]]; then
    echo "error: --view/--read doesn't combine with the upload-mode flags" >&2
    exit 1
  fi
fi
if $list_created; then
  if $no_encrypt || $public || [[ -n "$update_id" ]] || [[ -n "$fetch_target" ]] || \
     $use_stdin || [[ -n "$file" ]] || [[ -n "$filename_override" ]] || \
     [[ -n "$mime_override" ]]; then
    echo "error: --created only takes --json" >&2
    exit 1
  fi
fi

# Parse --update target ("<id>" or "<id>#k=<key>", or a full rendered URL).
update_key_from_url=""
if [[ -n "$update_id" ]]; then
  parse_target "$update_id"
  update_id="$parsed_id"
  update_key_from_url="$parsed_key"
fi

command -v gh   >/dev/null || { echo "error: gh not installed (https://cli.github.com)" >&2; exit 1; }
command -v jq   >/dev/null || { echo "error: jq not installed" >&2; exit 1; }
command -v file >/dev/null || { echo "error: file(1) not installed" >&2; exit 1; }
command -v base64 >/dev/null || { echo "error: base64 not installed" >&2; exit 1; }
# Crypto tools needed unless this invocation is purely plain-mode upload, plain
# --created, etc. The defaults make encryption the common path, so just always
# require them on any non-listing invocation.
if ! $list_created; then
  command -v openssl >/dev/null || { echo "error: openssl not installed" >&2; exit 1; }
  command -v xxd     >/dev/null || { echo "error: xxd not installed" >&2; exit 1; }
fi
gh auth status >/dev/null 2>&1 || { echo "error: not logged in. run: gh auth login" >&2; exit 1; }

if [[ -n "$fetch_target" ]]; then
  parse_target "$fetch_target"
  fetch_id="$parsed_id"
  fetch_key="$parsed_key"

  response=$(gh api "gists/$fetch_id") || {
    echo "error: failed to fetch gist $fetch_id" >&2; exit 1; }

  meta_content=$(jq -r '.files["_meta.json"].content // empty' <<<"$response")
  if [[ -z "$meta_content" ]]; then
    # Old-style gist with no _meta.json: fall back to first file
    filename=$(jq -r '.files | to_entries[0].key' <<<"$response")
    mime_type=$(jq -r --arg fn "$filename" '.files[$fn].type // "text/plain"' <<<"$response")
    encoding="raw"
    content=$(jq -r --arg fn "$filename" '.files[$fn].content' <<<"$response")
  else
    encrypted_flag=$(jq -r '.encrypted // false' <<<"$meta_content")
    if [[ "$encrypted_flag" == "true" ]]; then
      [[ -n "$fetch_key" ]] || {
        echo "error: this share is encrypted; pass '<gist-id>#k=<key>'" >&2
        exit 1; }
      payload_b64=$(jq -r '.files["payload.b64"].content' <<<"$response")
      inner_json=$(printf '%s' "$payload_b64" | decrypt_payload "$fetch_key") || exit 1
      filename=$(jq -r '.filename' <<<"$inner_json")
      mime_type=$(jq -r '.mime_type' <<<"$inner_json")
      encoding=$(jq -r '.encoding' <<<"$inner_json")
      content=$(jq -r '.content' <<<"$inner_json")
      cache_key "$fetch_id" "$fetch_key"
    else
      filename=$(jq -r '.filename' <<<"$meta_content")
      mime_type=$(jq -r '.mime_type' <<<"$meta_content")
      encoding=$(jq -r '.encoding' <<<"$meta_content")
      content=$(jq -r --arg fn "$filename" '.files[$fn].content' <<<"$response")
    fi
  fi

  if [[ -n "$read_target" ]]; then
    jq -n --arg fn "$filename" --arg mt "$mime_type" --arg enc "$encoding" --arg c "$content" \
      '{filename: $fn, mime_type: $mt, encoding: $enc, content: $c}'
    exit 0
  fi

  # --view: write a local HTML wrapper to a private temp dir and open it.
  # `open data:...` is no longer supported on macOS (LaunchServices has no
  # handler for the data: scheme), so we launch via a local .html file
  # instead. Binary types are embedded as data: URLs *inside* the HTML,
  # which still works because the browser is already loaded and handles
  # the embedded data: URL natively (only top-level navigation is blocked).
  view_dir=$(mktemp -d "${TMPDIR:-/tmp}/share-file.XXXXXX")
  chmod 700 "$view_dir"
  view_html="$view_dir/view.html"

  if [[ "$encoding" == "base64" ]]; then
    content_b64=$(printf '%s' "$content" | tr -d '[:space:]')
  else
    content_b64=""
  fi

  title_escaped=$(printf '%s' "$filename" | \
    sed -e 's/&/\&amp;/g' -e 's/</\&lt;/g' -e 's/>/\&gt;/g' -e 's/"/\&quot;/g')

  {
    printf '<!DOCTYPE html>\n<html lang="en"><head><meta charset="utf-8">\n'
    printf '<title>%s</title>\n<style>\n' "$title_escaped"
    cat <<'CSS'
html,body{margin:0;padding:0;background:#1a1a1a;color:#eee;font-family:system-ui,-apple-system,sans-serif}
body{min-height:100vh;display:flex;align-items:center;justify-content:center}
img,video{max-width:100%;max-height:100vh;display:block}
embed{width:100vw;height:100vh}
pre{margin:0;padding:1em;width:100%;min-height:100vh;box-sizing:border-box;overflow:auto;white-space:pre-wrap;word-wrap:break-word;font:13px/1.5 ui-monospace,SF Mono,Menlo,monospace;background:#1a1a1a;color:#eee;align-self:stretch}
audio{width:80%;max-width:600px}
.dl{padding:2em;text-align:center}.dl a{color:#6af;text-decoration:none}.dl a:hover{text-decoration:underline}
CSS
    printf '</style></head><body>\n'

    case "$mime_type" in
      text/html)
        printf '%s' "$content"
        ;;
      text/*|application/json|application/xml|application/javascript|application/x-yaml|application/yaml)
        printf '<pre>'
        printf '%s' "$content" | sed -e 's/&/\&amp;/g' -e 's/</\&lt;/g' -e 's/>/\&gt;/g'
        printf '</pre>'
        ;;
      image/*)
        [[ -n "$content_b64" ]] || content_b64=$(printf '%s' "$content" | openssl base64 -A)
        printf '<img src="data:%s;base64,%s" alt="%s">' "$mime_type" "$content_b64" "$title_escaped"
        ;;
      application/pdf)
        printf '<embed src="data:%s;base64,%s" type="%s">' "$mime_type" "$content_b64" "$mime_type"
        ;;
      audio/*)
        printf '<audio controls src="data:%s;base64,%s"></audio>' "$mime_type" "$content_b64"
        ;;
      video/*)
        printf '<video controls src="data:%s;base64,%s"></video>' "$mime_type" "$content_b64"
        ;;
      *)
        [[ -n "$content_b64" ]] || content_b64=$(printf '%s' "$content" | openssl base64 -A)
        printf '<div class="dl"><p>%s (%s)</p>' "$title_escaped" "$mime_type"
        printf '<p><a href="data:%s;base64,%s" download="%s">Download</a></p></div>' \
          "$mime_type" "$content_b64" "$title_escaped"
        ;;
    esac

    printf '\n</body></html>\n'
  } > "$view_html"
  chmod 600 "$view_html"

  if command -v open >/dev/null 2>&1; then
    open "$view_html" && echo "Opened $filename in browser."
  elif command -v xdg-open >/dev/null 2>&1; then
    xdg-open "$view_html" && echo "Opened $filename in browser."
  elif command -v wslview >/dev/null 2>&1; then
    wslview "$view_html" && echo "Opened $filename in browser."
  else
    printf 'file://%s\n' "$view_html"
    echo "(no browser opener found; path printed above — open in your browser)" >&2
  fi

  # Leave the wrapper in place so browser refresh keeps working; the OS
  # reaps $TMPDIR on its own schedule. Intentionally not registered in
  # TMP_PATHS so the EXIT trap doesn't touch it.
  exit 0
fi

if $list_created; then
  # All share-file gists, joined with the local key cache so encrypted rows
  # show their full rendered URL when the key is available. Filter on the
  # presence of _meta.json (the structural marker; the [ShareFile] description
  # prefix was added later and isn't on older gists).
  raw_gists=$(gh api 'gists?per_page=100' --paginate)

  # The list API returns file metadata only (no content), so detect encrypted
  # via payload.b64's presence.
  rows=$(jq -r '
    [ .[]
      | select(.files | has("_meta.json"))
      | { id: .id,
          updated: .updated_at,
          desc: ((.description // "") | sub("^\\[ShareFile\\] *"; "")),
          encrypted: (.files | has("payload.b64")),
        }
    ] | sort_by(.updated) | reverse | .[]
    | [.id, .updated, .desc, (if .encrypted then "1" else "0" end)] | @tsv
  ' <<<"$raw_gists")

  if $output_json; then
    json_rows=()
    while IFS=$'\t' read -r id updated desc enc_flag; do
      [[ -z "$id" ]] && continue
      url="${VIEWER_BASE}?${id}"
      key=""
      if [[ "$enc_flag" == "1" ]] && [[ -f "$KEY_CACHE_DIR/$id" ]]; then
        key=$(cat "$KEY_CACHE_DIR/$id")
        url="${url}#k=${key}"
      fi
      json_rows+=("$(jq -n --arg id "$id" --arg url "$url" --arg updated "$updated" \
        --arg desc "$desc" --argjson encrypted "$([[ "$enc_flag" == "1" ]] && echo true || echo false)" \
        --argjson key_available "$([[ -n "$key" ]] && echo true || echo false)" \
        '{gist_id: $id, rendered_url: $url, updated_at: $updated,
          description: $desc, encrypted: $encrypted, key_available: $key_available}')")
    done <<<"$rows"
    if [[ ${#json_rows[@]} -eq 0 ]]; then
      echo "[]"
    else
      printf '%s\n' "${json_rows[@]}" | jq -s '.'
    fi
  else
    printed=0
    while IFS=$'\t' read -r id updated desc enc_flag; do
      [[ -z "$id" ]] && continue
      printed=$((printed + 1))
      date_only="${updated%%T*}"
      url="${VIEWER_BASE}?${id}"
      tag="plain    "
      suffix=""
      if [[ "$enc_flag" == "1" ]]; then
        tag="encrypted"
        if [[ -f "$KEY_CACHE_DIR/$id" ]]; then
          key=$(cat "$KEY_CACHE_DIR/$id")
          url="${url}#k=${key}"
        else
          suffix="  (key not on this machine)"
        fi
      fi
      printf '%s  %s  %s%s\n' "$date_only" "$tag" "$url" "$suffix"
    done <<<"$rows"
    if (( printed == 0 )); then
      echo "(no share-file gists found)" >&2
    fi
  fi
  exit 0
fi

if $use_stdin; then
  [[ -n "$filename_override" ]] || { echo "error: --stdin requires --filename" >&2; exit 1; }
  src_path=$(reg_tmp "$(mktemp)")
  cat > "$src_path"
  filename="$filename_override"
else
  [[ -n "$file" ]] || usage
  [[ -f "$file" ]] || { echo "error: file not found: $file" >&2; exit 1; }
  src_path="$file"
  filename="${filename_override:-$(basename "$file")}"
fi

if [[ "$filename" == "_meta.json" ]]; then
  echo "error: filename '_meta.json' is reserved" >&2
  exit 1
fi

if [[ -n "$mime_override" ]]; then
  mime_type="$mime_override"
else
  mime_type=$(file --mime-type -b "$src_path")
fi

# text-ish MIME types are stored raw; everything else is base64-encoded
case "$mime_type" in
  text/*|application/json|application/xml|application/javascript|application/x-yaml|application/yaml|image/svg+xml)
    encoding="raw"
    content=$(cat "$src_path")
    ;;
  *)
    encoding="base64"
    content=$(base64 < "$src_path" | tr -d '\n')
    ;;
esac

# For --update, fetch the existing gist so we can detect its mode (plain vs
# encrypted) and the old file's name. Both matter for safe mode switching:
# the old file gets nulled out in the PATCH so the gist doesn't end up with
# stale leftovers from the previous mode.
existing_mode=""
existing_old_filename=""
if [[ -n "$update_id" ]]; then
  existing_response=$(gh api "gists/$update_id") || {
    echo "error: failed to fetch gist $update_id" >&2; exit 1; }
  existing_meta=$(jq -r '.files["_meta.json"].content // empty' <<<"$existing_response")
  if [[ -z "$existing_meta" ]]; then
    existing_mode="plain"
    existing_old_filename=$(jq -r '.files | to_entries[0].key' <<<"$existing_response")
  else
    existing_enc=$(jq -r '.encrypted // false' <<<"$existing_meta")
    if [[ "$existing_enc" == "true" ]]; then
      existing_mode="encrypted"
      existing_old_filename="payload.b64"
    else
      existing_mode="plain"
      existing_old_filename=$(jq -r '.filename' <<<"$existing_meta")
    fi
  fi
fi

master_key_b64url=""
if $encrypt; then
  # For encrypted updates, reuse the original key so the URL stays stable.
  # The key lives only in the rendered URL fragment, so --update needs it.
  existing_key=""
  if [[ -n "$update_id" ]]; then
    if [[ -n "$update_key_from_url" ]]; then
      existing_key="$update_key_from_url"
      if [[ "$existing_mode" == "plain" ]]; then
        echo "warning: switching from plain to encrypted; the rendered URL now requires #k=..." >&2
      fi
    else
      if [[ "$existing_mode" == "encrypted" ]]; then
        echo "error: this share is encrypted; pass '<gist-id>#k=<key>' so the key can be reused." >&2
        echo "  You passed a bare gist ID. To convert to plain, use --no-encrypt." >&2
        exit 1
      fi
      echo "warning: switching from plain to encrypted; the rendered URL now requires #k=..." >&2
    fi
  fi

  inner_json=$(jq -n --arg fn "$filename" --arg mt "$mime_type" \
    --arg enc "$encoding" --arg c "$content" \
    '{filename: $fn, mime_type: $mt, encoding: $enc, content: $c}')

  encrypt_out=$(printf '%s' "$inner_json" | encrypt_payload "$existing_key")
  master_key_b64url="${encrypt_out%%$'\n'*}"
  payload_b64="${encrypt_out#*$'\n'}"

  filename="payload.b64"
  content="$payload_b64"
  encoding="encrypted"
  meta_json=$(jq -n '{encrypted: true, version: 1, alg: "AES-128-CBC+HMAC-SHA256"}')
else
  if [[ -n "$update_id" && "$existing_mode" == "encrypted" ]]; then
    echo "warning: switching from encrypted to plain; the old rendered URL with #k=... no longer" >&2
    echo "  decrypts. The new URL is the bare gist ID (?$update_id) — share holders need to update." >&2
    rm -f "$KEY_CACHE_DIR/$update_id" 2>/dev/null || true
  fi
  meta_json=$(jq -n --arg fn "$filename" --arg mt "$mime_type" --arg enc "$encoding" \
    '{filename: $fn, mime_type: $mt, encoding: $enc}')
fi

size=${#content}
if (( size > SIZE_LIMIT )); then
  echo "error: payload is ${size} bytes (>${SIZE_LIMIT}), gist may reject or truncate" >&2
  if $encrypt; then
    echo "  encryption adds ~33% base64 overhead on top of the original encoding" >&2
  elif [[ "$encoding" == "base64" ]]; then
    echo "  binary files are base64-encoded (~33% overhead); try a smaller file" >&2
  else
    echo "  check for inline base64 images or embedded datasets" >&2
  fi
  exit 1
fi

if [[ -n "$update_id" ]]; then
  files_obj=$(jq -n --arg meta "$meta_json" --arg fn "$filename" --arg c "$content" \
    '{} | .["_meta.json"] = {content: $meta} | .[$fn] = {content: $c}')
  # Null out the previous file when its name changes (mode switch or rename),
  # so the gist doesn't accumulate stale leftovers.
  if [[ -n "$existing_old_filename" && "$existing_old_filename" != "$filename" \
        && "$existing_old_filename" != "_meta.json" ]]; then
    files_obj=$(jq --arg ofn "$existing_old_filename" '.[$ofn] = null' <<<"$files_obj")
  fi
  body=$(jq -n --argjson files "$files_obj" '{files: $files}')
  response=$(gh api -X PATCH "gists/$update_id" --input - <<<"$body")
  gist_id="$update_id"
else
  # Prefix description so users can identify gists created by share-file.
  final_desc="[ShareFile] $desc"
  body=$(jq -n --arg desc "$final_desc" --argjson public "$public" \
    --arg fn "$filename" --arg c "$content" --arg meta "$meta_json" \
    '{description: $desc, public: $public,
      files: ({} | .["_meta.json"] = {content: $meta} | .[$fn] = {content: $c})}')
  response=$(gh api -X POST gists --input - <<<"$body")
  gist_id=$(jq -r '.id' <<<"$response")
fi

source_url=$(jq -r '.html_url' <<<"$response")
rendered_url="${VIEWER_BASE}?${gist_id}"
if $encrypt; then
  rendered_url="${rendered_url}#k=${master_key_b64url}"
  cache_key "$gist_id" "$master_key_b64url"
fi

if $output_json; then
  jq -n --arg id "$gist_id" --arg src "$source_url" --arg rendered "$rendered_url" \
    --arg fn "$filename" --arg mt "$mime_type" --arg enc "$encoding" \
    --argjson encrypted "$encrypt" \
    '{gist_id: $id, source_url: $src, rendered_url: $rendered,
      filename: $fn, mime_type: $mt, encoding: $enc, encrypted: $encrypted}'
else
  echo "Source:   $source_url"
  echo "Rendered: $rendered_url"
  if command -v pbcopy >/dev/null 2>&1; then
    printf '%s' "$rendered_url" | pbcopy && echo "(copied to clipboard)" >&2
  elif command -v xclip >/dev/null 2>&1; then
    printf '%s' "$rendered_url" | xclip -selection clipboard \
      && echo "(copied to clipboard)" >&2
  fi
fi
}

# Run main only when invoked directly (not when sourced by tests).
if [[ "${BASH_SOURCE[0]}" == "${0}" ]]; then
  main "$@"
fi
